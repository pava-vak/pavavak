<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.USE_BIOMETRIC" />
    <uses-permission android:name="android.permission.USE_FINGERPRINT" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <application
        android:name=".PaVaVakApp"
        android:allowBackup="false"
        android:icon="@drawable/icon_512"
        android:label="@string/app_name"
        android:networkSecurityConfig="@xml/network_security_config"
        android:roundIcon="@drawable/icon_512"
        android:supportsRtl="true"
        android:theme="@style/Theme.PaVaVak"
        android:usesCleartextTraffic="true">

        <activity
            android:name=".nativechat.ChatActivity"
            android:exported="false"
            android:screenOrientation="portrait"
            android:windowSoftInputMode="adjustResize|stateHidden" />

        <activity
            android:name=".nativechat.ChatListActivity"
            android:exported="false"
            android:screenOrientation="portrait" />

        <activity
            android:name=".LoginActivity"
            android:exported="false"
            android:screenOrientation="portrait" />

        <activity
            android:name=".UserWebActivity"
            android:exported="false"
            android:screenOrientation="portrait" />

        <activity
            android:name=".AdminWebActivity"
            android:exported="false"
            android:screenOrientation="portrait" />

        <activity
            android:name=".AdminMessagesActivity"
            android:exported="false"
            android:screenOrientation="portrait" />

        <activity
            android:name=".AdminHomeActivity"
            android:exported="false"
            android:screenOrientation="portrait" />

        <activity
            android:name=".SettingsActivity"
            android:exported="false"
            android:screenOrientation="portrait" />

        <activity
            android:name=".AdminConversationActivity"
            android:exported="false"
            android:screenOrientation="portrait" />

        <activity
            android:name=".AdminConversationListActivity"
            android:exported="false"
            android:screenOrientation="portrait" />

        <activity
            android:name=".LockActivity"
            android:exported="false"
            android:screenOrientation="portrait"
            android:theme="@style/Theme.PaVaVak" />

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:screenOrientation="portrait">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <service
            android:name=".notifications.PaVaVakFirebaseMessagingService"
            android:exported="false">
            <intent-filter>
                <action android:name="com.google.firebase.MESSAGING_EVENT" />
            </intent-filter>
        </service>

    </application>

</manifest>
