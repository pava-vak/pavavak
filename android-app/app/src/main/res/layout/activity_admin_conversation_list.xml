<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/screen_bg">

    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/adminConnToolbar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:title="All Conversations"
        android:titleTextColor="@color/text_primary"
        android:background="@color/top_bar_bg"
        app:navigationIcon="@android:drawable/ic_menu_revert" />

    <androidx.swiperefreshlayout.widget.SwipeRefreshLayout
        android:id="@+id/adminConnSwipeRefresh"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent">

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/adminConnRecycler"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:padding="10dp" />

            <ProgressBar
                android:id="@+id/adminConnProgress"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center" />

            <TextView
                android:id="@+id/adminConnEmpty"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:gravity="center"
                android:textColor="@color/text_secondary"
                android:visibility="gone"
                android:padding="16dp" />
        </FrameLayout>
    </androidx.swiperefreshlayout.widget.SwipeRefreshLayout>

</LinearLayout>

