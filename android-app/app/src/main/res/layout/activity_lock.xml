<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="24dp"
    android:gravity="center"
    android:background="#101010">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="PaVa-Vak"
        android:textColor="#FFFFFF"
        android:textSize="30sp"
        android:textStyle="bold"
        android:layout_marginBottom="10dp" />

    <TextView
        android:id="@+id/subtitleText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/pin_hint"
        android:textColor="#D0D0D0"
        android:textSize="16sp"
        android:layout_marginBottom="8dp" />

    <TextView
        android:id="@+id/setupHelpText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/pin_setup_help"
        android:textColor="#9FB0C8"
        android:textSize="12sp"
        android:layout_marginBottom="12dp" />

    <EditText
        android:id="@+id/pinInput"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:inputType="numberPassword"
        android:maxLength="4"
        android:textColor="#FFFFFF"
        android:textColorHint="#A0A0A0"
        android:hint="****"
        android:padding="14dp"
        android:backgroundTint="#1B5E20" />

    <Button
        android:id="@+id/unlockButton"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="14dp"
        android:text="@string/unlock" />

    <Button
        android:id="@+id/biometricButton"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:text="@string/use_biometric" />

    <Button
        android:id="@+id/changePinButton"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:text="@string/change_real_pin" />

    <Button
        android:id="@+id/decoyPinButton"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="@string/set_or_change_decoy_pin" />

    <TextView
        android:id="@+id/errorText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textColor="#FF8A80"
        android:layout_marginTop="12dp"
        android:text=""
        android:visibility="gone" />

</LinearLayout>
