// Prisma Schema for PaVa-Vak
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Users table
model users {
  user_id            Int       @id @default(autoincrement())
  username           String    @unique
  email              String    @unique
  password_hash      String
  full_name          String?
  is_admin           Boolean   @default(false)
  is_approved        Boolean   @default(false)
  two_factor_enabled Boolean   @default(false)
  two_factor_secret  String?
  created_at         DateTime  @default(now())
  last_login         DateTime?
  reset_token        String?
  reset_token_expiry DateTime?

  // Relations
  connections_user1       connections[]               @relation("User1Connections")
  connections_user2       connections[]               @relation("User2Connections")
  messages_sent           messages[]                  @relation("SentMessages")
  messages_received       messages[]                  @relation("ReceivedMessages")
  invite_codes_used       invite_codes[]
  admin_logs              admin_logs[]
  login_attempts          login_attempts[]
  password_reset_requests password_reset_requests[]
  device_tokens           device_tokens[]
}

// Device tokens for FCM push notifications
model device_tokens {
  id           Int      @id @default(autoincrement())
  user_id      Int
  token        String   @unique
  platform     String   @default("android")
  device_id    String?
  is_active    Boolean  @default(true)
  last_seen_at DateTime @default(now())
  created_at   DateTime @default(now())
  updated_at   DateTime @updatedAt

  user users @relation(fields: [user_id], references: [user_id], onDelete: Cascade)

  @@index([user_id, is_active])
}

// Invite codes
model invite_codes {
  code               String   @id
  used               Boolean  @default(false)
  created_at         DateTime @default(now())
  used_by_user_id    Int?
  created_by_user_id Int?

  used_by_user users? @relation(fields: [used_by_user_id], references: [user_id], onDelete: SetNull)
}

// Connections between users
model connections {
  connection_id Int      @id @default(autoincrement())
  user1_id      Int
  user2_id      Int
  status        String   @default("active")
  created_at    DateTime @default(now())

  user1                       users                        @relation("User1Connections", fields: [user1_id], references: [user_id], onDelete: Cascade)
  user2                       users                        @relation("User2Connections", fields: [user2_id], references: [user_id], onDelete: Cascade)
  conversation_timer_settings conversation_timer_settings?

  @@unique([user1_id, user2_id])
}

// Messages
model messages {
  message_id           Int       @id @default(autoincrement())
  sender_id            Int
  receiver_id          Int
  content              String
  sent_at              DateTime  @default(now())
  is_read              Boolean   @default(false)
  read_at              DateTime?
  deleted_for_sender   Boolean   @default(false)
  deleted_for_receiver Boolean   @default(false)

  sender         users           @relation("SentMessages",   fields: [sender_id],   references: [user_id], onDelete: Cascade)
  receiver       users           @relation("ReceivedMessages", fields: [receiver_id], references: [user_id], onDelete: Cascade)
  message_timers message_timers?

  @@index([sender_id, receiver_id])
}

// Message timers
model message_timers {
  message_id       Int       @id
  timer_type       String
  duration_seconds Int?
  expires_at       DateTime?

  messages messages @relation(fields: [message_id], references: [message_id], onDelete: Cascade)
}

// Conversation timer settings
model conversation_timer_settings {
  user1_id                 Int
  user2_id                 Int
  default_timer_type       String
  default_duration_seconds Int?

  connection connections @relation(fields: [user1_id, user2_id], references: [user1_id, user2_id], onDelete: Cascade)

  @@id([user1_id, user2_id])
}

// Admin logs
model admin_logs {
  log_id       Int      @id @default(autoincrement())
  admin_id     Int
  action       String
  details      String?
  performed_at DateTime @default(now())

  admin users @relation(fields: [admin_id], references: [user_id], onDelete: Cascade)
}

// System logs
model system_logs {
  log_id     Int      @id @default(autoincrement())
  level      String   @default("INFO")
  action     String
  message    String?
  metadata   String?
  event_type String?
  details    String?
  timestamp  DateTime @default(now())
  logged_at  DateTime @default(now())

  @@index([event_type, logged_at])
  @@index([timestamp])
}

// Login attempts
model login_attempts {
  attempt_id   Int      @id @default(autoincrement())
  user_id      Int
  success      Boolean
  ip_address   String?
  attempted_at DateTime @default(now())

  user users @relation(fields: [user_id], references: [user_id], onDelete: Cascade)
}

// Sessions
model sessions {
  session_id String   @id
  user_id    Int
  data       String
  expires_at DateTime

  @@index([expires_at])
}

// Password reset requests
model password_reset_requests {
  request_id  Int       @id @default(autoincrement())
  user_id     Int
  status      String    @default("pending")
  created_at  DateTime  @default(now())
  resolved_at DateTime?

  user users @relation(fields: [user_id], references: [user_id], onDelete: Cascade)
}
